# ─────────────────────────────────────────
#  APOPHERO HEALTH — ENVIRONMENT VARIABLES
#  Copy this file to .env and fill values
# ─────────────────────────────────────────

# ── APP ──────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ── MONGODB ──────────────────────────────
# Get from MongoDB Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/apophero?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ── ADMIN SEED ───────────────────────────
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@apopherohealth.com
ADMIN_PASSWORD=ChangeMe@2026!

# ── EMAIL (SMTP) ─────────────────────────
# For Gmail: enable 2FA then create App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
FROM_NAME=Apophero Health
FROM_EMAIL=hello@apopherohealth.com

# ── RATE LIMITING ────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── FILE UPLOADS ─────────────────────────
MAX_FILE_SIZE=5242880
